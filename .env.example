# Keep loopback for brain-only work. For Apple container, use this Mac's exact
# private LAN IPv4; do not use 0.0.0.0.
HOST=127.0.0.1
MC_WIZARD_LAN_IP=
PORT=3000
BRIDGE_TOKEN=dev-only-change-me
REQUEST_COOLDOWN_MS=1500
ADMIN_HOST=127.0.0.1
ADMIN_PORT=3001
RUNTIME_SETTINGS_FILE=runtime/admin/settings.json

# Leave these blank for the built-in offline demo mode.
# OpenAI: set AI_API_KEY and keep AI_STYLE=responses.
# OpenRouter/Ollama/other compatible APIs: set AI_STYLE=chat and AI_BASE_URL.
AI_STYLE=responses
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=gpt-5.6-luna
AI_PROVIDER_LABEL=
AI_TIMEOUT_MS=35000
AI_MAX_OUTPUT_TOKENS=3000
AI_GENERAL_MAX_OUTPUT_TOKENS=1200

# Safe local mtok-bridge -> Ollama example:
# AI_STYLE=chat
# AI_BASE_URL=http://127.0.0.1:8790/v1
# AI_MODEL=llama3.2:1b
# AI_PROVIDER_LABEL=Ollama
# Start it with: npm run start:ai
# For authenticated Codex CLI in ephemeral read-only mode with tools disabled:
# MTOK_PROVIDER=codex
# MTOK_MODEL=gpt-5.6-luna
# For authenticated Grok CLI with memory, subagents, web, and tools disabled:
# MTOK_PROVIDER=grok
# MTOK_MODEL=grok
# For authenticated Claude CLI with all tools disabled and no saved session:
# MTOK_PROVIDER=claude
# MTOK_MODEL=claude
MTOK_TIMEOUT_MS=30000
# Optional: leave blank to derive a private per-install salt from BRIDGE_TOKEN.
WIZARD_SALT=
SESSION_FILE=runtime/brain/sessions.json
SESSION_MAX_TURNS=12
SESSION_TTL_MS=86400000
