{
  "name": "mc-wizard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node --env-file-if-exists=.env src/server.mjs",
    "start:ai": "node --env-file-if-exists=.env scripts/local-ai-bridge.mjs",
    "wizard:start": "node --env-file-if-exists=.env scripts/supervisor.mjs start",
    "wizard:stop": "node --env-file-if-exists=.env scripts/supervisor.mjs stop",
    "wizard:status": "node --env-file-if-exists=.env scripts/supervisor.mjs status",
    "admin:start": "node --env-file-if-exists=.env scripts/admin-service.mjs start",
    "admin:stop": "node --env-file-if-exists=.env scripts/admin-service.mjs stop",
    "admin:status": "node --env-file-if-exists=.env scripts/admin-service.mjs status",
    "hooks:install": "git config core.hooksPath .githooks",
    "dev": "node --env-file-if-exists=.env --watch src/server.mjs",
    "ask": "node --env-file-if-exists=.env scripts/ask.mjs",
    "eval:dialogue": "node --env-file-if-exists=.env scripts/eval-dialogue.mjs",
    "eval:live-chat": "node --test test/live-chat-regressions.test.mjs",
    "bootstrap:bds": "sh scripts/bootstrap-bedrock.sh",
    "enable:beta": "python3 scripts/enable-beta-apis.py",
    "install:pack": "node --env-file-if-exists=.env scripts/install-pack.mjs",
    "generate:textures": "node scripts/generate-wizard-textures.mjs",
    "package:skin": "npm run generate:textures && sh scripts/package-skin-pack.sh",
    "container:bds": "sh scripts/run-bedrock-container.sh",
    "container:start": "sh scripts/start-bedrock-container.sh",
    "container:delete": "container delete mc-wizard-bedrock",
    "container:logs": "container logs -f mc-wizard-bedrock",
    "container:stop": "sh scripts/stop-bedrock-container.sh",
    "sync:docs": "node scripts/sync-docs.mjs",
    "test": "node --test test/*.test.mjs",
    "test:e2e:bds": "sh scripts/run-e2e-container.sh",
    "test:e2e:machines": "MC_WIZARD_E2E_SCOPE=machines sh scripts/run-e2e-container.sh",
    "test:e2e:commands": "MC_WIZARD_E2E_SCOPE=commands sh scripts/run-e2e-container.sh",
    "test:e2e:arbitrary": "MC_WIZARD_E2E_SCOPE=arbitrary sh scripts/run-e2e-container.sh",
    "test:e2e:portal": "MC_WIZARD_E2E_SCOPE=portal sh scripts/run-e2e-container.sh",
    "test:e2e:travel-rollback": "MC_WIZARD_E2E_SCOPE=travel-rollback sh scripts/run-e2e-container.sh",
    "test:e2e:city": "MC_WIZARD_E2E_SCOPE=city sh scripts/run-e2e-container.sh",
    "test:e2e:child": "MC_WIZARD_E2E_SCOPE=child sh scripts/run-e2e-container.sh",
    "test:e2e:refinement": "MC_WIZARD_E2E_SCOPE=refinement sh scripts/run-e2e-container.sh",
    "test:e2e:feedback": "MC_WIZARD_E2E_SCOPE=feedback sh scripts/run-e2e-container.sh",
    "test:e2e:farms": "MC_WIZARD_E2E_SCOPE=farms sh scripts/run-e2e-container.sh",
    "test:e2e:kelp": "MC_WIZARD_E2E_SCOPE=kelp sh scripts/run-e2e-container.sh",
    "test:e2e:delivery": "MC_WIZARD_E2E_SCOPE=delivery sh scripts/run-e2e-container.sh",
    "test:e2e:logs": "container logs -f mc-wizard-bedrock 2>&1 | node scripts/wait-e2e.mjs"
  },
  "engines": {
    "node": ">=22.9.0"
  },
  "dependencies": {
    "mtok-bridge": "^0.2.0"
  }
}
